# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sentinelx
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=sentinelx
DATABASE_USER=username
DATABASE_PASSWORD=password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=SentinelX
VERSION=1.0.0
DESCRIPTION=Enterprise Cybersecurity Platform

# CORS Configuration
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000","http://169.254.83.107:3000","https://sentinelx.com"]

# WebSocket Configuration
WEBSOCKET_PATH=/ws

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Security
BCRYPT_ROUNDS=12
SESSION_EXPIRE_HOURS=24

# Detection Engine
DETECTION_ENGINE_ENABLED=true
DETECTION_RULES_PATH=./detection_rules/
THREAT_INTEL_UPDATE_INTERVAL=3600

# SOAR Configuration
SOAR_ENABLED=true
SOAR_PLAYBOOKS_PATH=./soar_playbooks/
SOAR_MAX_CONCURRENT_EXECUTIONS=10

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
